generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum ProductStatus {
  ACTIVE
  SOLD
  DELETE
  ARCHIVED
}

model Brand {
  id      Int      @id
  name    String
  filters Filter[]
}

model Filter {
  id          Int             @id @default(autoincrement())
  search      String
  min_cost    Int
  max_cost    Int
  brand_id    Int?
  brand       Brand?          @relation(fields: [brand_id], references: [id])
  products    Product[]
  category_id Int?
  category    VintedCategory? @relation(fields: [category_id], references: [id])
  colors      FilterColor[]
  states      FilterState[]

  @@unique([search, min_cost, max_cost, brand_id])
}

model Product {
  id          Int             @id @default(autoincrement())
  url         String          @unique
  status      ProductStatus
  img         String?
  price       Decimal
  likes       Int             @default(0)
  filter_id   Int
  filter      Filter          @relation(fields: [filter_id], references: [id], onDelete: Cascade)
  size        String?
  state       String?
  member_id   Int?
  member      Member?         @relation(fields: [member_id], references: [id])
  category_id Int?
  category    VintedCategory? @relation(fields: [category_id], references: [id])
  sell_at     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Member {
  id       Int       @id
  name     String
  star     Decimal
  review   Int
  products Product[]
}

model Category {
  id        Int             @id @default(autoincrement())
  name      String
  parent_id Int?
  parent    Category?       @relation("CategoryTree", fields: [parent_id], references: [id])
  children  Category[]      @relation("CategoryTree")
  position  Int             @default(0)
  vinted    VintedCategory?
}

model VintedCategory {
  id          Int       @id
  category_id Int       @unique
  products    Product[]
  category    Category  @relation(fields: [category_id], references: [id])
  filters     Filter[]
}

model State {
  id           Int           @id @default(autoincrement())
  name         String
  filterStates FilterState[]
}

model Color {
  id           Int           @id
  name         String
  filterColors FilterColor[]
}

model FilterColor {
  filter_id Int
  color_id  Int
  filter    Filter @relation(fields: [filter_id], references: [id], onDelete: Cascade)
  color     Color  @relation(fields: [color_id], references: [id], onDelete: Cascade)

  @@id([filter_id, color_id])
}

model FilterState {
  filter_id Int
  state_id  Int
  filter    Filter @relation(fields: [filter_id], references: [id], onDelete: Cascade)
  state     State  @relation(fields: [state_id], references: [id], onDelete: Cascade)

  @@id([filter_id, state_id])
}
