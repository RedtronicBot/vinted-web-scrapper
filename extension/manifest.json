{
	"manifest_version": 3,
	"name": "Vinted Reupload",
	"version": "1.0.0",
	"description": "Reupload Vinted items easily",
	"permissions": ["tabs", "storage"],
	"background": {
		"service_worker": "background.js"
	},
	"host_permissions": ["https://www.vinted.fr/*", "https://extensionapi.redtrotool.fr/*"],
	"content_scripts": [
		{
			"matches": ["https://www.vinted.fr/*"],
			"js": ["content.js"]
		}
	]
}
